{
  "ignorePathPrefixes": [
    "web/src/lib/api/",
    "web/src/lib/assets/",
    "web/src/lib/components/ui/",
    "web/src/lib/i18n/",
    "web/src/lib/testing/",
    "web/src/test/"
  ],
  "ignorePathSubstrings": ["/testdata/", ".test.", ".spec."],
  "translatableAttributes": ["aria-label", "title", "placeholder", "alt"],
  "suspiciousPropertyNames": [
    "label",
    "title",
    "description",
    "placeholder",
    "message",
    "subtitle",
    "helperText",
    "emptyText",
    "buttonText",
    "ctaLabel",
    "prompt"
  ],
  "allowedLiteralPatterns": [
    "^OpenASE$",
    "^⌘[A-Z]$",
    "^https?://",
    "^/[A-Za-z0-9_./:?=&-]+$",
    "^[A-Z0-9_:-]+$",
    "^[A-Za-z0-9_.-]+@[A-Za-z0-9.-]+$",
    "^openase(?: [a-z0-9:_./-]+)+$"
  ]
}
