{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "api:generate": "openapi-typescript ../api/openapi.json -o src/lib/api/generated/openapi.d.ts && prettier --write src/lib/api/generated/openapi.d.ts",
    "api:check": "pnpm run api:generate && git diff --exit-code -- ../api/openapi.json src/lib/api/generated/openapi.d.ts",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "test": "svelte-kit sync && vitest run",
    "test:ticket-run-transcript": "svelte-kit sync && vitest run src/lib/features/ticket-detail/run-transcript-real-samples.test.ts src/lib/features/ticket-detail/run-transcript-live-updates.test.ts src/lib/features/ticket-detail/run-transcript.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=phone-390x844-iphone --project=phone-430x932-android --project=phone-360x800-compact --project=tablet-768x1024-portrait --project=tablet-1024x768-landscape",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:structure": "node scripts/check-file-budgets.mjs",
    "lint:deps": "node scripts/check-dependency-boundaries.mjs",
    "lint:mobile": "node scripts/check-mobile-route-gates.mjs",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "prettier --check --log-level warn . && eslint . --quiet && node scripts/check-file-budgets.mjs && node scripts/check-dependency-boundaries.mjs && node scripts/check-mobile-route-gates.mjs && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --output machine --threshold error && vitest run --reporter=dot src/lib/features/ticket-detail/run-transcript-real-samples.test.ts src/lib/features/ticket-detail/run-transcript-live-updates.test.ts src/lib/features/ticket-detail/run-transcript.test.ts && vite build --logLevel warn && playwright test --reporter=dot --quiet"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^24.6.1",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-svelte": "^3.12.5",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@lucide/svelte": "^0.577.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.19",
    "streamdown-svelte": "^3.0.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  }
}
