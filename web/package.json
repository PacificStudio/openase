{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "api:generate": "openapi-typescript ../api/openapi.json -o src/lib/api/generated/openapi.d.ts && prettier --write src/lib/api/generated/openapi.d.ts",
    "api:check": "pnpm run api:generate && git diff --exit-code -- ../api/openapi.json src/lib/api/generated/openapi.d.ts",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "test": "svelte-kit sync && vitest run",
    "test:ticket-run-transcript": "svelte-kit sync && vitest run src/lib/features/ticket-detail/run-transcript-real-samples.test.ts src/lib/features/ticket-detail/run-transcript-live-updates.test.ts src/lib/features/ticket-detail/run-transcript.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=phone-390x844-iphone --project=phone-430x932-android --project=phone-360x800-compact --project=tablet-768x1024-portrait --project=tablet-1024x768-landscape",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "pnpm run lint:eslint && pnpm run lint:i18n",
    "lint:eslint": "eslint . --quiet",
    "lint:i18n": "node scripts/check-i18n-registry.mjs && node scripts/check-i18n.mjs",
    "lint:structure": "node scripts/check-file-budgets.mjs",
    "lint:deps": "node scripts/check-dependency-boundaries.mjs && node scripts/check-lockfile-security.mjs",
    "lint:mobile": "node scripts/check-mobile-route-gates.mjs",
    "check:security-overrides": "node scripts/check-security-overrides.mjs",
    "lint:fix": "eslint . --fix",
    "sort:i18n-locales": "node scripts/sort-i18n-locales.mjs",
    "format": "pnpm run sort:i18n-locales && prettier --log-level warn --write .",
    "format:check": "pnpm run sort:i18n-locales -- --check && prettier --log-level warn --check .",
    "ci": "pnpm run format:check && pnpm run lint && node scripts/check-file-budgets.mjs && pnpm run lint:deps && node scripts/check-mobile-route-gates.mjs && pnpm run check:security-overrides && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --output machine --threshold error && vitest run --reporter=dot src/lib/i18n/index.test.ts src/lib/components/layout/top-bar.test.ts src/lib/components/layout/top-bar-user-menu.test.ts src/lib/components/layout/sidebar-nav.test.ts src/lib/components/layout/theme-root.test.ts src/lib/features/ticket-detail/run-transcript-real-samples.test.ts src/lib/features/ticket-detail/run-transcript-live-updates.test.ts src/lib/features/ticket-detail/run-transcript.test.ts && vite build --logLevel warn && playwright test --reporter=dot --quiet"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^24.6.1",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-svelte": "^3.12.5",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@lucide/svelte": "^0.577.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bits-ui": "^2.16.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.19",
    "shiki": "^4.0.2",
    "streamdown-svelte": "^3.0.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": "4.18.1"
    }
  }
}
