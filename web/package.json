    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.12.5",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "typescript-eslint": "^8.46.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
